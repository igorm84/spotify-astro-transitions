---
interface Props {
  title: string;
  image?: string;
}

const {
  title = "Home",
  image = "https://res.cloudinary.com/dp3ppkxo5/image/upload/v1693776174/spotify-astro/playlist_2_f9ymlx.jpg",
} = Astro.props;
import { ClientRouter } from "astro:transitions";
import "./layout.css";
import SideMenu from "../components/Side/SideMenu.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Clone of Spotify with Astro View Transitions integration for fluid navigation"
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Spotify Astro</title>
    <meta property="og:image" content={image} />
    <meta name="twitter:image" content={image} />
    <ClientRouter fallback="none" />
  </head>
  <body class="dark">
    <div class="relative h-screen p-2 gap-2 flex items-stretch">
      <div class="w-[350px] flex-col hidden lg:flex overflow-y-auto">
        <SideMenu />
      </div>
      <div class="rounded-lg bg-zinc-900 flex-1 mx-auto overflow-y-auto">
        <slot />
      </div>
    </div>
    <div
      id="not-support"
      class="fixed hidden bg-red-700 bottom-0 inset-x-0 rounded-t-md text-center py-2 lg:py-4 z-50 font-semibold"
    >
      View transitions are unavailable in this browser. Navigation still works
      without animations. <a
        class="underline"
        href="https://github.com/igorm84/spotify-astro-transitions"
        >(see docs here)</a
      >
    </div>
    <script>
      const HOVER_COLOR_DELAY = 200;
      const initializedPlaylistItems = new WeakSet<HTMLElement>();
      let hoverColorTimeout: ReturnType<typeof setTimeout> | undefined;

      function setContainerColor(color: string) {
        const playlistContainer = document.getElementById("playlist-container");

        if (color !== playlistContainer?.dataset.color) {
          playlistContainer?.style.setProperty("--context-color", color);
          playlistContainer?.setAttribute("data-color", color);
        }
      }

      function clearHoverColorTimeout() {
        if (hoverColorTimeout !== undefined) {
          clearTimeout(hoverColorTimeout);
          hoverColorTimeout = undefined;
        }
      }

      function getPlaylistColor(playlist: HTMLElement) {
        return playlist.dataset.color;
      }

      function updateColorFromFocus(playlist: HTMLElement) {
        const color = getPlaylistColor(playlist);

        if (color) setContainerColor(color);
      }

      function updateColorFromHover(playlist: HTMLElement) {
        const color = getPlaylistColor(playlist);

        if (color) {
          hoverColorTimeout = setTimeout(
            () => setContainerColor(color),
            HOVER_COLOR_DELAY
          );
        }
      }

      function initializePageBehavior() {
        if (typeof document.startViewTransition !== "function") {
          document.getElementById("not-support")?.classList.remove("hidden");
        }

        for (const playlist of document.querySelectorAll<HTMLElement>(
          ".playlist-item"
        )) {
          if (initializedPlaylistItems.has(playlist)) continue;

          initializedPlaylistItems.add(playlist);
          playlist.addEventListener("mouseover", () =>
            updateColorFromHover(playlist)
          );
          playlist.addEventListener("mouseout", clearHoverColorTimeout);
          playlist.addEventListener("focus", () =>
            updateColorFromFocus(playlist)
          );
          playlist.addEventListener("blur", clearHoverColorTimeout);
        }
      }

      function revealFadedElements() {
        for (const el of document.querySelectorAll(".el-to-fade")) {
          el.classList.remove("scale-90");
        }
      }

      document.addEventListener("astro:before-swap", clearHoverColorTimeout);
      document.addEventListener("astro:page-load", () => {
        initializePageBehavior();
        revealFadedElements();
      });
      window.addEventListener("load", revealFadedElements, { once: true });
      initializePageBehavior();
    </script>
  </body>
</html>
