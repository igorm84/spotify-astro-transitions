---
import { Icon } from "astro-icon/components";

interface Props {
  size?: "md" | "lg";
  interactive?: boolean;
}

const { size = "md", interactive = false } = Astro.props;
---

{
  interactive ? (
    <button
      type="button"
      aria-label="Play playlist"
      class="bg-green-500 hover:scale-105 shadow-md shadow-black/40 rounded-full flex items-center justify-center text-black"
      class:list={[
        size === "md" && "h-12 w-12",
        size === "lg" && "h-14 w-14",
      ]}
    >
      <Icon
        name="mdi:play"
        is:inline
        aria-hidden="true"
        class:list={[
          size === "md" && "h-8 w-8",
          size === "lg" && "h-10 w-10",
        ]}
      />
    </button>
  ) : (
    <span
      aria-hidden="true"
      class="bg-green-500 hover:scale-105 shadow-md shadow-black/40 rounded-full flex items-center justify-center text-black"
      class:list={[
        size === "md" && "h-12 w-12",
        size === "lg" && "h-14 w-14",
      ]}
    >
      <Icon
        name="mdi:play"
        is:inline
        class:list={[
          size === "md" && "h-8 w-8",
          size === "lg" && "h-10 w-10",
        ]}
      />
    </span>
  )
}
